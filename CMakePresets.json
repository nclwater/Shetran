{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 12,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Configuration",
      "description": "Default build configuration with auto-detected compiler",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Configuration",
      "description": "Debug build with symbols and runtime checks",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ifort",
      "displayName": "Intel Fortran (Classic)",
      "description": "Build with Intel Fortran Compiler (ifort)",
      "binaryDir": "${sourceDir}/build-ifort",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_Fortran_COMPILER": "ifort"
      }
    },
    {
      "name": "ifx",
      "displayName": "Intel Fortran (LLVM)",
      "description": "Build with Intel Fortran Compiler (ifx)",
      "binaryDir": "${sourceDir}/build-ifx",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_Fortran_COMPILER": "ifx"
      }
    },
    {
      "name": "gfortran",
      "displayName": "GNU Fortran",
      "description": "Build with GNU Fortran Compiler",
      "binaryDir": "${sourceDir}/build-gfortran",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_Fortran_COMPILER": "gfortran"
      }
    },
    {
      "name": "windows-ifort",
      "displayName": "Windows Intel Fortran",
      "description": "Windows build with Intel Fortran",
      "binaryDir": "${sourceDir}/build-windows",
      "generator": "NMake Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_Fortran_COMPILER": "ifort"
      }
    },
    {
      "name": "small-memory",
      "displayName": "Small Memory Configuration",
      "description": "Build with reduced memory requirements",
      "binaryDir": "${sourceDir}/build-small-memory",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_LARGE_MEMORY_MODEL": "OFF",
        "HEAP_ARRAY_SIZE": "10000000",
        "STACK_VAR_SIZE": "10000000"
      }
    },
    {
      "name": "custom-memory",
      "displayName": "Custom Memory Configuration",
      "description": "Build with custom memory settings",
      "binaryDir": "${sourceDir}/build-custom-memory",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HEAP_ARRAY_SIZE": "50000000",
        "STACK_VAR_SIZE": "50000000"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "displayName": "Build Default",
      "description": "Build with default configuration"
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Build Debug",
      "description": "Build debug version"
    },
    {
      "name": "ifort",
      "configurePreset": "ifort",
      "displayName": "Build with Intel Fortran (Classic)",
      "description": "Build with ifort compiler"
    },
    {
      "name": "ifx",
      "configurePreset": "ifx",
      "displayName": "Build with Intel Fortran (LLVM)",
      "description": "Build with ifx compiler"
    },
    {
      "name": "gfortran",
      "configurePreset": "gfortran",
      "displayName": "Build with GNU Fortran",
      "description": "Build with gfortran compiler"
    },
    {
      "name": "small-memory",
      "configurePreset": "small-memory",
      "displayName": "Build with Small Memory",
      "description": "Build with reduced memory requirements"
    },
    {
      "name": "custom-memory",
      "configurePreset": "custom-memory",
      "displayName": "Build with Custom Memory",
      "description": "Build with custom memory settings"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "displayName": "Test Default",
      "description": "Run tests with default configuration"
    }
  ]
}
